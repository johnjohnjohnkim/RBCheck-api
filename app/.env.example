# Copy this file to .env and fill in real values.
# Never commit the real .env — it is gitignored.
# Secure it: chmod 600 .env
#
# No secrets ship inside the binary. The recipient provides all values below.

# ── PostgreSQL connection ─────────────────────────────────────────────────────
DATABASE_HOSTNAME=    # Postgres host, e.g. localhost or 10.0.0.5
DATABASE_PORT=        # Postgres port, typically 5432
DATABASE_USERNAME=    # Postgres role/user
DATABASE_PASSWORD=    # Postgres password
DATABASE_NAME=        # Database name
DATABASE_POOL_SIZE=   # Drogon connection pool size (default: 5)

# ── HTTP listener ─────────────────────────────────────────────────────────────
LISTEN_HOST=          # Bind address (default: 0.0.0.0)
LISTEN_PORT=          # Bind port (default: 8080)

# ── Backfill mode (--backfill only) ──────────────────────────────────────────
RBC_HANDLE_ID=        # iMessage handle ROWID for the RBC SMS shortcode
RBC_CHATDB_PATH=      # Path to chat.db (default: $HOME/Library/Messages/chat.db)
